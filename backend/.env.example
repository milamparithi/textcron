# LLM_PROVIDER=openai        | openai | gemini | anthropic | groq | ollama | azure | ...
# LLM_API_KEY                | API key for the chosen provider
# LLM_MODEL=gpt-4o-mini      | model name (e.g. gemini-2.0-flash, claude-3-haiku)
# LLM_BASE_URL=              | optional custom endpoint (e.g. http://localhost:11434 for Ollama)
# LLM_TEMPERATURE=0

LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_TEMPERATURE=0

# Langfuse (for LLM tracing + feedback)
# Cloud:   LANGFUSE_HOST=https://cloud.langfuse.com
# Self-host via docker-compose: LANGFUSE_HOST=http://localhost:3000
# (docker-compose.yml overrides this to http://langfuse:3000 automatically)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

